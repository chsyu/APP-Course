rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function sharedJournalDocPath(journalId) {
      return /databases/$(database)/documents/sharedJournals/$(journalId);
    }

    function authEmailLower() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    // 須與 client 的 where('memberEmails','array-contains', auth.currentUser.email 小寫) 對齊；陣列元素須為字串且與 JWT email 小寫完全一致
    function isEmailMemberOfSharedJournal(data) {
      return request.auth != null
        && request.auth.token.email != null
        && data.memberEmails is list
        && data.memberEmails.size() > 0
        && data.memberEmails.hasAny([authEmailLower()]);
    }

    function sharedJournalData(journalId) {
      return get(sharedJournalDocPath(journalId)).data;
    }

    // 成員可依 memberEmails；擁有者另允許（雲端殘缺／被移出列表時仍可讀寫以修復）
    function isSharedJournalMember(journalId) {
      return request.auth != null
        && exists(sharedJournalDocPath(journalId))
        && (
          isEmailMemberOfSharedJournal(sharedJournalData(journalId))
          || (
            sharedJournalData(journalId).ownerUid is string
            && sharedJournalData(journalId).ownerUid == request.auth.uid
          )
        );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /diaries/{diaryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // uid 查頭像／暱稱（與 publicProfilesByEmail 分工，無法合併為單一集合而不犧牲查詢路徑）
    match /publicProfiles/{profileUid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == profileUid;
    }

    match /publicProfilesByEmail/{emailKey} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email != null
        && authEmailLower() == emailKey;
    }

    // 每位使用者依「小寫 email」子路徑列出自己的分享日誌 id；setDoc(merge) 已存在文件時為 update，須一併允許
    match /userSharedJournalRefs/{emailKey}/journals/{journalId} {
      allow read: if request.auth != null
        && request.auth.token.email != null
        && emailKey == authEmailLower();

      allow create, update, delete: if request.auth != null
        && exists(sharedJournalDocPath(journalId))
        && sharedJournalData(journalId).ownerUid is string
        && sharedJournalData(journalId).ownerUid == request.auth.uid;
    }

    // 讀：成員可讀 meta；擁有者亦必須能讀（否則殘缺文件會讓 getDoc 權限錯誤、無法重建）
    match /sharedJournals/{journalId} {
      allow read: if request.auth != null
        && (
          isEmailMemberOfSharedJournal(resource.data)
          || (resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid)
        );

      allow create: if request.auth != null
        && request.auth.token.email != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberEmails is list
        && request.resource.data.memberEmails.size() > 0
        && isEmailMemberOfSharedJournal(request.resource.data);

      // 擁有者可更新（含修復 memberEmails）；須維持 ownerUid 不變且更新後仍為有效分享日誌
      allow update: if request.auth != null
        && request.auth.token.email != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.memberEmails is list
        && request.resource.data.memberEmails.size() > 0
        && isEmailMemberOfSharedJournal(request.resource.data);

      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;

      match /diaries/{diaryId} {
        allow read: if isSharedJournalMember(journalId);

        allow create: if isSharedJournalMember(journalId)
          && request.resource.data.keys().hasAll(['createdByEmail'])
          && request.resource.data.createdByEmail is string
          && request.resource.data.createdByEmail.lower() == authEmailLower();

        allow update: if isSharedJournalMember(journalId)
          && resource.data.createdByEmail is string
          && resource.data.createdByEmail.lower() == authEmailLower()
          && request.resource.data.createdByEmail == resource.data.createdByEmail;

        allow delete: if isSharedJournalMember(journalId)
          && resource.data.createdByEmail is string
          && resource.data.createdByEmail.lower() == authEmailLower();
      }
    }
  }
}
